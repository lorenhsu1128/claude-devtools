{
  "$schema": "https://unpkg.com/knip@next/schema.json",
  "entry": [
    "src/main/index.ts",
    "src/main/standalone.ts",
    "src/preload/index.ts",
    "src/renderer/main.tsx",
    "electron.vite.config.ts",
    "vite.standalone.config.ts",
    "src/tui/index.tsx",
    "vite.tui.config.ts"
  ],
  "project": ["src/**/*.{ts,tsx}!"],
  "ignore": ["tsconfig*.json"],
  "paths": {
    "@main/*": ["./src/main/*"],
    "@renderer/*": ["./src/renderer/*"],
    "@preload/*": ["./src/preload/*"],
    "@shared/*": ["./src/shared/*"],
    "@tui/*": ["./src/tui/*"]
  },
  "ignoreBinaries": ["pkg"]
}
